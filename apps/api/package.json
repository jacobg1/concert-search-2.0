{
  "name": "concert-search-api",
  "version": "1.0.0",
  "description": "concert-search-back-end",
  "author": "jacob-greenwald",
  "private": true,
  "scripts": {
    "build": "rm -rf ./dist && nest build --webpack",
    "build:watch": "npm run build -- --watch",
    "deploy": "serverless deploy --stage prod",
    "deploy:test": "serverless deploy --stage test",
    "dev": "WITH_MOCKS=true npm run build:watch & WITH_MOCKS=true nest build --webpack && nodemon ./dist/main.js",
    "start": "node ./dist/main.js",
    "test": "jest",
    "test:watch": "jest --watch --collectCoverage=false",
    "lint": "eslint .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "archive-search": "^1.1.15",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "lodash.chunk": "4.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@darraghor/eslint-plugin-nestjs-typed": "^7.1.30",
    "@babel/preset-env": "7.29.2",
    "@nestjs/testing": "^11.1.19",
    "@repo/eslint-config": "*",
    "@repo/jest-config": "*",
    "@repo/mock-data": "*",
    "@repo/ts-config": "*",
    "@types/aws-lambda": "8.10.161",
    "@types/aws-serverless-express": "^3.3.10",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/lodash.chunk": "4.2.9",
    "@types/node": "^24.1.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "body-parser": "^2.2.2",
    "copy-webpack-plugin": "^14.0.0",
    "dotenv-webpack": "^9.0.0",
    "esbuild-register": "^3.6.0",
    "express": "^5.2.1",
    "jest": "^30.3.0",
    "msw": "^2.10.3",
    "nock": "^13.5.6",
    "nodemon": "3.1.14",
    "path-to-regexp": "^8.4.2",
    "terser-webpack-plugin": "^5.4.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7"
  }
}
