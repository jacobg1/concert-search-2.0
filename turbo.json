{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "start": {
      "dependsOn": ["build"]
    },
    "build": {
      "dependsOn": ["lint", "^build"],
      "outputs": [".next/**", "!.next/cache/**", "build/**"]
    },
    "build:cdk": {
      "outputs": ["cdk.out/**", "dist-cdk/**"],
      "env": ["STAGE"]
    },
    "build:watch": {
      "persistent": true,
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "deploy": {
      "cache": false,
      "dependsOn": ["test", "deploy:base"],
      "env": [
        "CDK_DEFAULT_ACCOUNT",
        "CDK_DEFAULT_REGION",
        "STAGE",
        "NODE_ENV",
        "AWS_CONTAINER_CREDENTIALS_RELATIVE_URI",
        "API_BASE_URL"
      ]
    },
    "deploy:base": {
      "cache": false,
      "dependsOn": ["build", "build:cdk"],
      "env": [
        "CDK_DEFAULT_ACCOUNT",
        "CDK_DEFAULT_REGION",
        "STAGE",
        "AWS_CONTAINER_CREDENTIALS_RELATIVE_URI",
        "API_BASE_URL"
      ]
    },
    "deploy:test": {
      "cache": false,
      "dependsOn": ["test", "deploy:test:base"],
      "env": [
        "CDK_DEFAULT_ACCOUNT",
        "CDK_DEFAULT_REGION",
        "STAGE",
        "NODE_ENV",
        "AWS_CONTAINER_CREDENTIALS_RELATIVE_URI",
        "API_BASE_URL"
      ]
    },
    "deploy:test:base": {
      "cache": false,
      "dependsOn": ["build", "build:cdk"],
      "env": [
        "CDK_DEFAULT_ACCOUNT",
        "CDK_DEFAULT_REGION",
        "STAGE",
        "AWS_CONTAINER_CREDENTIALS_RELATIVE_URI",
        "API_BASE_URL"
      ]
    },
    "destroy:test:base": {
      "dependsOn": ["build", "build:cdk"],
      "env": [
        "CDK_DEFAULT_ACCOUNT",
        "CDK_DEFAULT_REGION",
        "STAGE",
        "AWS_CONTAINER_CREDENTIALS_RELATIVE_URI",
        "API_BASE_URL"
      ]
    },
    "destroy:test": {
      "dependsOn": ["destroy:test:base"],
      "env": [
        "CDK_DEFAULT_ACCOUNT",
        "CDK_DEFAULT_REGION",
        "STAGE",
        "AWS_CONTAINER_CREDENTIALS_RELATIVE_URI",
        "API_BASE_URL"
      ]
    },
    "test": {
      "dependsOn": ["^test"],
      "env": [
        "NEXT_PUBLIC_BASE_URL"
      ]
    },
    "test:watch": {
      "persistent": true,
      "cache": false,
      "env": [
        "NEXT_PUBLIC_BASE_URL"
      ]
    }
  }
}
